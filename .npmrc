# Nuxt 2 / webpack 4 and several @nuxtjs modules assume a flat, hoisted
# node_modules (like npm/yarn). pnpm's default isolated layout breaks their
# module resolution, so hoist everything to the root node_modules.
shamefully-hoist=true

# This project has long-standing transitive peer-dep mismatches (webpack 4
# era). Don't fail installs on them.
strict-peer-dependencies=false
